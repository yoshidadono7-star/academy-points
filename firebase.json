{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "README.md",
      "HANDOFF.md",
      "CLAUDE_HEROS_STORYTELLING.md",
      "session-report.html",
      "session-report-v2.html",
      "system-overview.html",
      "game-design-v2.html",
      "detailed-specs.html",
      "phase1-plan.html",
      "storytelling-phase1.html",
      "annual-plan.html",
      "*.docx"
    ],
    "rewrites": [
      {
        "source": "/briefing",
        "destination": "/briefing.html"
      },
      {
        "source": "/student",
        "destination": "/student.html"
      },
      {
        "source": "/parent",
        "destination": "/parent.html"
      },
      {
        "source": "/teacher",
        "destination": "/teacher.html"
      },
      {
        "source": "/classroom",
        "destination": "/briefing.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
