rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 管理者（Firebase Auth認証済み）
    function isAdmin() {
      return request.auth != null;
    }

    // === 管理者のみ作成・削除 / 生徒もupdate可能 ===

    match /students/{studentId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if true;
    }

    match /raidBosses/{bossId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if true;
    }

    // === 管理者専用 ===

    match /tasks/{taskId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /prizes/{prizeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /examResults/{resultId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /missions/{missionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /rewards/{rewardId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /guilds/{guildId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /activeSessions/{studentId} {
      allow read: if true;
      allow write: if true;
    }

    match /storyChapters/{chapterId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // === 生徒もcreate可能 / update・deleteは管理者のみ ===

    match /studyLogs/{logId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /conditions/{conditionId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /badges/{badgeId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /prizeHistory/{historyId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /raidDamage/{damageId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /taskCompletions/{completionId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /coins/{coinId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /rewardHistory/{historyId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /comboTriggers/{triggerId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /comboDiscoveries/{discoveryId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /hiddenAreaDiscoveries/{discoveryId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /supportActions/{actionId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /supportLogs/{logId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // === 生徒もcreate・update可能 ===

    match /notifications/{notifId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    match /dailyMissionDraws/{drawId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    match /stationProgress/{progressId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    match /fcmTokens/{tokenId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    // 出席管理
    match /attendance/{attendanceId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    // 日次プラン
    match /dailyPlans/{planId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if true;
      allow delete: if isAdmin();
    }

    // 教材進捗
    match /materialProgress/{progressId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    // テスト日程
    match /examSchedules/{scheduleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ���習ルート
    match /studyRoutes/{routeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ルートタスク
    match /routeTasks/{taskId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    // 塾設定
    match /academyConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 講師管理
    match /teachers/{teacherId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // シフト管理
    match /shifts/{shiftId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    // スケジュールテンプレート
    match /scheduleTemplates/{templateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // スケジュールスロット
    match /scheduleSlots/{slotId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    // 出欠可否（保護者）
    match /availability/{availId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    // 業務タスク
    match /operationTasks/{taskId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }
  }
}
