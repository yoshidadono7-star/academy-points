rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 管理者（Firebase Auth認証済み）のみ書き込み可能
    function isAdmin() {
      return request.auth != null;
    }

    // --- 管理者専用（先生のみ書き込み） ---

    // 生徒マスタ（登録・編集は管理画面から）
    match /students/{studentId} {
      allow read: true;
      allow write: if isAdmin();
    }

    // タスク管理
    match /tasks/{taskId} {
      allow read: true;
      allow write: if isAdmin();
    }

    // 景品マスタ
    match /prizes/{prizeId} {
      allow read: true;
      allow write: if isAdmin();
    }

    // レイドボス管理
    match /raidBosses/{bossId} {
      allow read: true;
      allow write: if isAdmin();
    }

    // テスト結果（先生が入力）
    match /examResults/{resultId} {
      allow read: true;
      allow write: if isAdmin();
    }

    // ミッション管理
    match /missions/{missionId} {
      allow read: true;
      allow write: if isAdmin();
    }

    // イベント管理
    match /events/{eventId} {
      allow read: true;
      allow write: if isAdmin();
    }

    // 報酬カタログ
    match /rewards/{rewardId} {
      allow read: true;
      allow write: if isAdmin();
    }

    // ギルド管理
    match /guilds/{guildId} {
      allow read: true;
      allow write: if isAdmin();
    }

    // ストーリーチャプター
    match /storyChapters/{chapterId} {
      allow read: true;
      allow write: if isAdmin();
    }

    // 塾設定
    match /settings/{settingId} {
      allow read: true;
      allow write: if isAdmin();
    }

    // --- 生徒も書き込み可能（PINベース認証のため制限不可） ---

    // 学習ログ
    match /studyLogs/{logId} {
      allow read: true;
      allow create: true;
      allow update, delete: if isAdmin();
    }

    // コンディション記録
    match /conditions/{conditionId} {
      allow read: true;
      allow create: true;
      allow update, delete: if isAdmin();
    }

    // バッジ（自動付与）
    match /badges/{badgeId} {
      allow read: true;
      allow create: true;
      allow update, delete: if isAdmin();
    }

    // メッセージ（先生→生徒 + 生徒の返信）
    match /messages/{messageId} {
      allow read: true;
      allow create: true;
      allow update, delete: if isAdmin();
    }

    // 景品交換履歴
    match /prizeHistory/{historyId} {
      allow read: true;
      allow create: true;
      allow update, delete: if isAdmin();
    }

    // レイドダメージログ
    match /raidDamage/{damageId} {
      allow read: true;
      allow create: true;
      allow update, delete: if isAdmin();
    }

    // 通知
    match /notifications/{notifId} {
      allow read: true;
      allow create: true;
      allow update: true;
      allow delete: if isAdmin();
    }

    // コイン取引履歴
    match /coins/{coinId} {
      allow read: true;
      allow create: true;
      allow update, delete: if isAdmin();
    }

    // 報酬交換履歴
    match /rewardHistory/{historyId} {
      allow read: true;
      allow create: true;
      allow update, delete: if isAdmin();
    }

    // デイリーミッション抽選
    match /dailyMissionDraws/{drawId} {
      allow read: true;
      allow create: true;
      allow update: true;
      allow delete: if isAdmin();
    }

    // コンボトリガー
    match /comboTriggers/{triggerId} {
      allow read: true;
      allow create: true;
      allow update, delete: if isAdmin();
    }

    // スペースマップ進捗
    match /stationProgress/{progressId} {
      allow read: true;
      allow create: true;
      allow update: true;
      allow delete: if isAdmin();
    }

    // サポート艦隊ログ
    match /supportLogs/{logId} {
      allow read: true;
      allow create: true;
      allow update, delete: if isAdmin();
    }
  }
}
