rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 管理者（Firebase Auth認証済み）
    function isAdmin() {
      return request.auth != null;
    }

    // === 管理者のみ作成・削除 / 生徒もupdate可能 ===

    match /students/{studentId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if true;
    }

    match /raidBosses/{bossId} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if true;
    }

    // === 管理者専用 ===

    match /tasks/{taskId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /prizes/{prizeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /examResults/{resultId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /missions/{missionId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /rewards/{rewardId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /guilds/{guildId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /activeSessions/{studentId} {
      allow read: if true;
      allow write: if true;
    }

    match /storyChapters/{chapterId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // === 生徒もcreate可能 / update・deleteは管理者のみ ===

    match /studyLogs/{logId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /conditions/{conditionId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /badges/{badgeId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /prizeHistory/{historyId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /raidDamage/{damageId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /taskCompletions/{completionId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /coins/{coinId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /rewardHistory/{historyId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /comboTriggers/{triggerId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /comboDiscoveries/{discoveryId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /hiddenAreaDiscoveries/{discoveryId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /supportActions/{actionId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /supportLogs/{logId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // === 生徒もcreate・update可能 ===

    match /notifications/{notifId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    match /dailyMissionDraws/{drawId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    match /stationProgress/{progressId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    match /fcmTokens/{tokenId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    // 出席管理
    match /attendance/{attendanceId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    // 日次プラン
    match /dailyPlans/{planId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if true;
      allow delete: if isAdmin();
    }

    // 教材進捗
    match /materialProgress/{progressId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    // テスト日程
    match /examSchedules/{scheduleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ���習ルート
    match /studyRoutes/{routeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ルートタス��
    match /routeTasks/{taskId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if isAdmin();
    }

    // === Phase 8: スケジュール・講師管理 ===

    match /academyConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /teachers/{teacherId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /shifts/{shiftId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /availability/{availId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /scheduleTemplates/{templateId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /scheduleSlots/{slotId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // === Phase 9: 面談・コメント・タスク・レポート ===

    match /interviewRecords/{recordId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /teacherComments/{commentId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /operationTasks/{taskId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reportLogs/{logId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    // === Phase 14: バディチャット ===
    match /chats/{studentId} {
      allow read, write: if true;
      match /messages/{messageId} {
        allow read, create: if true;
        allow update, delete: if isAdmin();
      }
    }

    // === Phase 14c: デジタル拠点 ===
    match /bases/{studentId} {
      allow read, write: if true;
    }

    // === Feature 9: 階層型コーチングシステム ===
    // classrooms: 教室マスタ。誰でも read（生徒画面のロード時に必要）。書き込みは管理者のみ。
    match /classrooms/{classroomId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // users: Firebase Auth uid に対応するロール管理。
    // セキュリティ強化 (2026-04): makeMeOwner() バックドア削除に合わせ、
    // role の書き換えを厳しく制限。owner 昇格は Firebase Console から手動設定のみ。
    match /users/{uid} {
      function isExistingOwner() {
        return request.auth != null
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
      }

      // 読み取り: 自分のレコード or 既存オーナー
      allow read: if request.auth != null
                  && (request.auth.uid == uid || isExistingOwner());

      // 作成: 自分のレコードのみ、かつ初期 role は 'admin' 固定
      // （owner を自分で作ることは不可。owner 昇格は Firebase Console 経由のみ）
      allow create: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.role == 'admin';

      // 更新(a): 自分のレコードを自分で更新 — ただし role フィールドは変更不可
      allow update: if request.auth != null
                    && request.auth.uid == uid
                    && request.resource.data.role == resource.data.role;
      // 更新(b): 既存オーナーは他人のレコード (role 含む) を変更できる
      allow update: if isExistingOwner();

      // 削除: 既存オーナーのみ
      allow delete: if isExistingOwner();
    }

    // dailyBriefing: 艦長マイケルのブリーフィングメッセージ（日毎キャッシュ）
    // ドキュメント ID = YYYY-MM-DD。aiMessage, manualOverride, context を保持。
    // 管理画面からの手動上書き / briefing.html からの AI キャッシュ書き込みの両方を許可。
    match /dailyBriefing/{dateId} {
      allow read: if true;
      allow write: if true;
    }

    // Feature 11 Phase D1: 特別付与テンプレート
    // grantTemplates: 誕生日・皆勤・新入生歓迎などのテンプレート定義
    // 管理画面から作成・編集、実行時は一覧取得が必要
    match /grantTemplates/{templateId} {
      allow read: if true;
      allow write: if true;
    }

    // Feature 11 Phase S1: 集団目標
    // collectiveGoals: 全員で貢献して達成する教室全体の目標
    // 生徒画面から貢献 (update)、管理画面から作成・編集が必要
    match /collectiveGoals/{goalId} {
      allow read: if true;
      allow write: if true;
    }

    // Feature 12 Phase X1: 個人目標
    // personalGoals: 生徒が自分で立てる週次目標
    // 生徒が作成、教室長が承認、システムが判定・ペナルティ実行
    match /personalGoals/{goalId} {
      allow read: if true;
      allow write: if true;
    }

    // 分散学習: 復習スケジュール
    match /reviewSchedules/{scheduleId} {
      allow read: if true;
      allow write: if true;
    }

    // X4: guildGoals: ギルド（チーム）単位の週次目標
    match /guildGoals/{goalId} {
      allow read: if true;
      allow write: if true;
    }

    // handoffLog: 階層間の申し送り（生徒バディ → 講師 → 教室長 → オーナー）。
    // 講師ポータル/オーナーポータルから書き込み（PIN ログインなのでクライアントから自由に）。
    // 将来的に Firestore Rules で role ベースの絞り込みを検討。
    match /handoffLog/{entryId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;        // markRead 等
      allow delete: if isAdmin();
    }

    // === Academy RPG 連携 (Step 5) ===
    // academy-points から RPG 側コレクションへ報酬を書き込むためのルール。
    // admin (isAdmin) が学習完了時に書き込む想定。本人は読み取りのみ。
    //
    // 注意: academy-rpg リポジトリの firestore.rules と整合を取ること。
    // 最後にデプロイした方が反映されるので、両リポジトリで同じ内容を維持する必要がある。

    // rpg_profiles: 生徒のRPGプロフィール (Lv, XP, avatarId等)
    match /rpg_profiles/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow create: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // rpg_wallet: ゴールド等の通貨
    match /rpg_wallet/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    // rpg_gacha_tickets: ガチャチケット保有数
    match /rpg_gacha_tickets/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    // rpg_daily_stats: 今日の学習統計 (minutes, pomodoros)
    match /rpg_daily_stats/{uid}/days/{dateId} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    // rpg_inventory: 獲得した装備・バディ
    match /rpg_inventory/{uid}/items/{itemId} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }

    // rpg_account_links: academy-points 生徒ID → RPG Google UID の紐付け
    // admin が管理画面から登録。生徒本人は読み取りのみ。
    match /rpg_account_links/{academyStudentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // rpg_minigame_results: ミニゲーム結果記録 (academy-rpg 側で書き込む)
    match /rpg_minigame_results/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // rpg_transactions: ゴールド取得・消費の履歴
    match /rpg_transactions/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // rpg_skill_rates: 科目別の習熟度レート
    match /rpg_skill_rates/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
    }
  }
}
