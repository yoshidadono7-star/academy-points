rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 家庭学習写真: 誰でもアップロード・閲覧可能
    match /homeStudyPhotos/{allPaths=**} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // その他はデフォルト拒否
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
